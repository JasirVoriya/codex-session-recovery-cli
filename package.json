{
  "name": "codex-session-recovery-cli",
  "version": "0.1.0",
  "description": "Analyze, migrate, repair, and roll back Codex sidebar session metadata from rollout files and state_5.sqlite.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-session-recovery": "./bin/codex-session-recovery.js"
  },
  "files": [
    "bin/**/*",
    "electron/**/*",
    "renderer/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "session",
    "recovery",
    "cli",
    "sqlite",
    "electron"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "npm run test && npm run smoke",
    "scan": "node ./src/cli.js scan",
    "migrate": "node ./src/cli.js migrate",
    "repair-state": "node ./src/cli.js repair-state",
    "rollback": "node ./src/cli.js rollback",
    "smoke": "node ./src/cli.js --help && node ./src/cli.js scan --help && node ./src/cli.js migrate --help && node ./src/cli.js repair-state --help && node ./src/cli.js rollback --help && node ./src/cli.js ui --help",
    "ui": "node ./src/cli.js ui",
    "gui": "electron ./electron/main.mjs",
    "gui:dev": "electron ./electron/main.mjs",
    "dist:mac": "electron-builder --mac dir",
    "dist:win": "electron-builder --win dir",
    "test": "node --test"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "blessed": "^0.1.81",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "smol-toml": "^1.4.1"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.jasirvoriya.codex-session-recovery",
    "productName": "Codex Session Recovery",
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "src/**/*",
      "bin/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": "dir",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "dir"
    }
  }
}
